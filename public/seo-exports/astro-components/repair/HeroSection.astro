---
interface Props {
  deviceName: string;
  slug: string;
  tagline?: string;
  description?: string;
  heroImage?: string;
  heroImageAlt?: string;
  hideImage?: boolean;
}

const {
  deviceName,
  slug,
  tagline = `${deviceName} Specialists in Winnipeg`,
  description = `Professional ${deviceName} repair in Winnipeg & Manitoba.`,
  heroImage = `/assets/hero-${slug}.png`,
  heroImageAlt = `${deviceName} repair services in Winnipeg`,
  hideImage = false,
} = Astro.props;

const showImage = !hideImage;
const REPAIR_WIDGET_URL = "https://shop.mobiletechlab.ca/pages/repair2";
const PRIMARY_PHONE_TEL = "+12044001499";
---

<section id="hero" class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-background to-primary/5 py-12 md:py-20">
  <div class="container mx-auto px-4">
    <div class:list={[
      showImage ? "grid items-center gap-8 lg:grid-cols-2 lg:gap-12" : "max-w-4xl mx-auto text-center"
    ]} set:html={undefined}>
      {/* Left Content */}
      <div>
        <div class:list={["mb-4 flex flex-wrap items-center gap-3", !showImage && "justify-center"]}>
          <span class="inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary">
            Professional {deviceName} Repair
          </span>
        </div>

        <h1 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
          {tagline}
        </h1>

        <p class:list={["mb-8 text-lg text-muted-foreground", !showImage && "mx-auto max-w-2xl"]}>
          {description}
        </p>

        <div class:list={["flex flex-col gap-4 sm:flex-row", !showImage && "justify-center"]}>
          <a
            href={REPAIR_WIDGET_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-lg font-medium text-primary-foreground shadow-sm hover:bg-primary/90 transition-colors"
          >
            Get a Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href={`tel:${PRIMARY_PHONE_TEL}`}
            class="inline-flex items-center justify-center rounded-md border border-border bg-background px-6 py-3 text-lg font-medium text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>

        <p class:list={["mt-4 text-sm text-muted-foreground", !showImage && "text-center"]}>
          Not sure what affects the cost?
          <a href="/repair-pricing" class="underline underline-offset-2 hover:text-primary transition-colors">
            How repair pricing works
          </a>
        </p>
      </div>

      {/* Right Image */}
      {!hideImage && (
        <div class="relative hidden lg:flex items-center justify-end">
          <img
            src={heroImage}
            alt={heroImageAlt}
            width="600"
            height="400"
            loading="eager"
            class="w-full max-w-xl object-contain"
          />
        </div>
      )}
    </div>
  </div>

  <!-- Background decorative elements -->
  <div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-primary/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-20 left-1/4 h-56 w-56 rounded-full bg-primary/5 blur-3xl" aria-hidden="true"></div>
</section>
