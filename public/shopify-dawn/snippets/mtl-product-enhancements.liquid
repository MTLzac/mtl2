<!-- ========================================================================
   SNIPPET 4: Quick Specs Badge (Optional)
   Add near the product title for key specs
   ======================================================================== -->

{% raw %}
<div class="mtl-quick-specs">
  <span class="mtl-spec-badge">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
    {{ product.metafields.custom.storage | default: "128GB" }}
  </span>
  <span class="mtl-spec-badge">
    {{ product.metafields.custom.carrier | default: "Unlocked" }}
  </span>
  <span class="mtl-spec-badge mtl-badge-success">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
    Certified
  </span>
</div>

<style>
  .mtl-quick-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.75rem 0;
  }
  
  .mtl-spec-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    background-color: hsl(var(--mtl-secondary-bg, 0 0% 96%));
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: hsl(var(--mtl-muted, 220 9% 46%));
  }
  
  .mtl-spec-badge svg {
    width: 0.875rem;
    height: 0.875rem;
  }
  
  .mtl-spec-badge.mtl-badge-success {
    background-color: hsl(142 76% 36% / 0.1);
    color: hsl(142 76% 36%);
  }
</style>
{% endraw %}
