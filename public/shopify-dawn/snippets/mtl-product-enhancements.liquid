<!-- ========================================================================
   SNIPPET 1: Condition Selector
   Add after the price block in main-product.liquid
   ======================================================================== -->

{% comment %}
  Uncomment and add this where you want the condition selector to appear.
  This works best with product variants or metafields for condition.
{% endcomment %}

{% raw %}
<div class="mtl-condition-selector">
  <h3 class="mtl-condition-label">Select Condition</h3>
  <div class="mtl-condition-options">
    <label class="mtl-condition-option">
      <input type="radio" name="condition" value="excellent" checked>
      <span class="mtl-condition-badge mtl-badge-success">Excellent</span>
      <span class="mtl-condition-desc">Minor signs of use, fully functional. May have light micro-scratches.</span>
    </label>
    <label class="mtl-condition-option">
      <input type="radio" name="condition" value="good">
      <span class="mtl-condition-badge mtl-badge-primary">Good</span>
      <span class="mtl-condition-desc">Light scratches, normal wear. Fully functional with visible signs of use.</span>
    </label>
    <label class="mtl-condition-option">
      <input type="radio" name="condition" value="fair">
      <span class="mtl-condition-badge mtl-badge-amber">Fair</span>
      <span class="mtl-condition-desc">Visible wear, minor cosmetic issues. Fully functional but shows character.</span>
    </label>
  </div>
</div>

<script>
  // Add selection state handling
  document.querySelectorAll('.mtl-condition-option input').forEach(input => {
    input.addEventListener('change', function() {
      document.querySelectorAll('.mtl-condition-option').forEach(opt => {
        opt.classList.remove('mtl-condition-selected');
      });
      this.closest('.mtl-condition-option').classList.add('mtl-condition-selected');
    });
  });
  // Set initial state
  document.querySelector('.mtl-condition-option:has(input:checked)')?.classList.add('mtl-condition-selected');
</script>
{% endraw %}


