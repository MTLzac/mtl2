<!-- ==========================================================================
   Mobile Tech Lab - Trade-In Banner Section
   File: sections/mtl-trade-in-banner.liquid
   ========================================================================== -->

<section class="mtl-trade-in-banner">
  <div class="page-width">
    <div class="mtl-trade-in-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    
    <div class="mtl-trade-in-actions">
      {% if section.settings.primary_button_text != blank %}
        <a href="{{ section.settings.primary_button_link }}" class="mtl-btn-primary">
          {{ section.settings.primary_button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {% endif %}
      
      {% if section.settings.secondary_button_text != blank %}
        <a href="{{ section.settings.secondary_button_link }}" class="mtl-btn-soft" style="background-color: rgba(255,255,255,0.1); color: white; border-color: rgba(255,255,255,0.3);">
          {{ section.settings.secondary_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .mtl-trade-in-banner {
    background-color: {{ section.settings.background_color }};
    color: white;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  
  .mtl-trade-in-banner .page-width {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }
  
  @media screen and (min-width: 990px) {
    .mtl-trade-in-banner .page-width {
      flex-direction: row;
      text-align: left;
      justify-content: space-between;
    }
  }
  
  .mtl-trade-in-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 0.5rem 0;
  }
  
  @media screen and (min-width: 750px) {
    .mtl-trade-in-content h2 {
      font-size: 2.25rem;
    }
  }
  
  .mtl-trade-in-content p {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    max-width: 500px;
  }
  
  .mtl-trade-in-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  
  @media screen and (min-width: 990px) {
    .mtl-trade-in-actions {
      justify-content: flex-end;
    }
  }
  
  .mtl-trade-in-banner .mtl-btn-primary {
    font-size: 1rem;
    padding: 1rem 2rem;
    background-color: hsl(4 74% 56%);
  }
  
  .mtl-trade-in-banner .mtl-btn-primary:hover {
    background-color: hsl(4 72% 47%);
  }
</style>

{% schema %}
{
  "name": "MTL Trade-In Banner",
  "tag": "section",
  "class": "section-mtl-trade-in",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Have a Device to Trade In?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get instant cash or credit toward your next device. We buy phones, tablets, laptops, and gaming consoles."
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Get a Quote"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link",
      "default": "https://mobiletechlab.ca/trade-in"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#21252b"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "MTL Trade-In Banner"
    }
  ]
}
{% endschema %}
