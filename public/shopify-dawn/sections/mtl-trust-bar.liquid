<!-- ==========================================================================
   Mobile Tech Lab - Trust Bar Section
   File: sections/mtl-trust-bar.liquid
   ========================================================================== -->

<section class="mtl-trust-bar">
  <div class="page-width">
    <div class="mtl-trust-items">
      {% for block in section.blocks %}
        <div class="mtl-trust-item" {{ block.shopify_attributes }}>
          {% case block.settings.icon %}
            {% when 'thumbs-up' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"/></svg>
            {% when 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% when 'map-pin' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {% when 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            {% when 'check-circle' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            {% when 'clock' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {% endcase %}
          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MTL Trust Bar",
  "tag": "section",
  "class": "section-mtl-trust-bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "thumbs-up", "label": "Thumbs Up" },
            { "value": "star", "label": "Star" },
            { "value": "map-pin", "label": "Map Pin" },
            { "value": "shield", "label": "Shield" },
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "clock", "label": "Clock" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust Badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MTL Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "thumbs-up",
            "text": "500+ 5-Star Reviews"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "star",
            "text": "4.8★ Google Rating"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "map-pin",
            "text": "2 Manitoba Locations"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "Price Match Guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}
